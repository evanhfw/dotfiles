{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        }
      ]
    },
    "oracle": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        {
          "model": "opencode-go/minimax-m2.7-highspeed"
        }
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2",
          "variant": "medium"
        }
      ]
    },
    "prometheus": {
      "model": "opencode-go/glm-5.1"
    },
    "metis": {
      "model": "opencode-go/glm-5.1"
    },
    "momus": {
      "model": "opencode-go/glm-5.1"
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.2",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/glm-5.1"
    },
    "ultrabrain": {
      "model": "opencode-go/glm-5.1"
    },
    "deep": {
      "model": "github-copilot/gpt-5.2",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },
    "quick": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        {
          "model": "github-copilot/claude-haiku-4.5"
        },
        {
          "model": "github-copilot/gemini-3-flash"
        }
      ]
    },
    "unspecified-low": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3-flash"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "writing": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        {
          "model": "github-copilot/claude-sonnet-4.6"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.2"
        }
      ]
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  }
}
